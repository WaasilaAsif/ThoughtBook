<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/canvas_card"
    android:layout_marginBottom="10dp"
    android:padding="14dp">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/logDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:src="@drawable/circle_dot"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/logMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/ink_secondary" />
    </LinearLayout>

    <TextView
        android:id="@+id/logNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/ink_primary"
        android:paddingTop="4dp" />

</LinearLayout>