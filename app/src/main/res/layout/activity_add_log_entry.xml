        <com.google.android.material.chip.ChipGroup
            android:id="@+id/emotionGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="true"
            app:selectionRequired="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/emotionJoyful"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Joyful"
                android:tag="#FFC857"
                app:chipIcon="@drawable/circle_dot"
                app:chipIconTint="#FFC857" />

            <com.google.android.material.chip.Chip
                android:id="@+id/emotionBittersweet"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bittersweet"
                android:tag="#8E7DBE"
                app:chipIcon="@drawable/circle_dot"
                app:chipIconTint="#8E7DBE" />

            <com.google.android.material.chip.Chip
                android:id="@+id/emotionCozy"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cozy"
                android:tag="#C97C5D"
                app:chipIcon="@drawable/circle_dot"
                app:chipIconTint="#C97C5D" />

            <com.google.android.material.chip.Chip
                android:id="@+id/emotionThrilling"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thrilling"
                android:tag="#D64550"
                app:chipIcon="@drawable/circle_dot"
                app:chipIconTint="#D64550" />

            <com.google.android.material.chip.Chip
                android:id="@+id/emotionMelancholy"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Melancholy"
                android:tag="#5C7AFF"
                app:chipIcon="@drawable/circle_dot"
                app:chipIconTint="#5C7AFF" />

            <com.google.android.material.chip.Chip
                android:id="@+id/emotionHopeful"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hopeful"
                android:tag="#6FCF97"
                app:chipIcon="@drawable/circle_dot"
                app:chipIconTint="#6FCF97" />

            <com.google.android.material.chip.Chip
                android:id="@+id/addEmotionChip"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Add"
                android:checkable="false" />

        </com.google.android.material.chip.ChipGroup>
        <TextView
            android:text="NOTE"
            android:textColor="@color/ink_secondary"
            android:textSize="12sp"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/noteInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="What's happening in the story right now?"
            android:background="@drawable/pill_bg"
            android:padding="14dp"
            android:textColor="@color/ink_primary"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save log entry"
            android:backgroundTint="@color/accent"
            android:layout_marginTop="20dp" />

        <Button
            android:id="@+id/deleteButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delete this log entry"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>