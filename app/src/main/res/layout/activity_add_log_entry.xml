<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="@drawable/pill_bg"
                android:padding="8dp"
                android:contentDescription="Back" />
            <TextView
                android:text="Add a log entry"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/ink_primary"
                android:layout_marginStart="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:text="CURRENT PAGE"
            android:textColor="@color/ink_secondary"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:background="@drawable/pill_bg"
            android:padding="12dp"
            android:layout_marginTop="8dp">

            <ImageButton
                android:id="@+id/pageMinusButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_button_bg"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Decrease page" />

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="center">
                <TextView
                    android:id="@+id/pageInput"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/ink_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <TextView
                    android:id="@+id/pageOfText"
                    android:text="of 0 pages"
                    android:textSize="12sp"
                    android:textColor="@color/ink_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/pagePlusButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_button_bg"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription="Increase page" />
        </LinearLayout>

        <TextView
            android:text="HOW DOES IT FEEL RIGHT NOW?"
            android:textColor="@color/ink_secondary"
            android:textSize="12sp"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

